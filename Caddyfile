# The mikr.us edge nginx terminates TLS (auto Let's Encrypt) and reverse-proxies
# plain HTTP to this container, so Caddy never handles certificates itself —
# it just serves the static SPA over HTTP. No hostname block / no `tls` needed.
:8080 {
	root * /srv
	encode zstd gzip

	# The edge passes the original scheme in X-Forwarded-Proto. Visitors who
	# arrived over HTTP get bounced to HTTPS — Chrome auto-upgrades the address
	# bar on its own, but Safari/Opera don't, so without this they load over
	# plain HTTP and the browser shows "Not secure".
	@http header X-Forwarded-Proto http
	redir @http https://{host}{uri}

	# Once a visitor has been served over HTTPS, force HTTPS for a year. The
	# header rides the HTTPS response the client gets back through the edge.
	header Strict-Transport-Security "max-age=31536000; includeSubDomains"

	# Single-page app: fall back to index.html for client-side routes.
	try_files {path} /index.html
	file_server
}
