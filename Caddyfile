{
	# Used by Let's Encrypt for expiry notices.
	email kkacper15@gmail.com

	# Another app (verum) owns host port 80, so never bind/redirect on it.
	auto_https disable_redirects
}

zwiedzamtu.pl {
	root * /srv
	encode zstd gzip

	# Single-page app: fall back to index.html for client-side routes.
	try_files {path} /index.html
	file_server

	# Issue the certificate over port 443 only (TLS-ALPN-01); the
	# HTTP-01 challenge would need port 80, which verum already holds.
	tls {
		issuer acme {
			disable_http_challenge
		}
	}
}
