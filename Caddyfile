{
	# Used by Let's Encrypt for expiry notices.
	email kkacper15@gmail.com

	# Another app (verum) owns host port 80, so never bind/redirect on it.
	auto_https disable_redirects
}

# Replace travel.tojest.dev with your real mikr.us subdomain. Its DNS A record
# must point to this VPS's IP, or Caddy will keep retrying the certificate.
zwiedzamtu.pl, travel.tojest.dev {
	root * /srv
	encode zstd gzip

	# Single-page app: fall back to index.html for client-side routes.
	try_files {path} /index.html
	file_server

	# Issue the certificate over port 443 only (TLS-ALPN-01); the
	# HTTP-01 challenge would need port 80, which verum already holds.
	tls {
		issuer acme {
			disable_http_challenge
		}
	}
}

# Plain HTTP for the mikr.us "Cytrus" subdomain proxy. Cytrus terminates
# HTTPS on its side and forwards to this internal port — no cert here.
# Has no hostname, so Caddy serves any Host and skips auto-HTTPS.
:8080 {
	root * /srv
	encode zstd gzip
	try_files {path} /index.html
	file_server
}
